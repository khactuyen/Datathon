      <aliases enabled='yes' />
      <column caption='Is Active RFM' datatype='integer' name='[Calculation_159330536444489511]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [rfm_segment] IN (&quot;Champions&quot;,&quot;Loyal Customers&quot;,&quot;New Customers&quot;,&quot;Potential Loyalists&quot;) THEN 1 ELSE 0 END' />
      </column>
      <column caption='First Order Date ' datatype='string' name='[Calculation_1683139774689280]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='RIGHT(&quot;0&quot; + STR(MONTH([first_order_date])),2) + &quot;/&quot; + STR(YEAR([first_order_date]))' />
      </column>
      <column caption='Churn Rate' datatype='real' name='[Calculation_1683139820093442]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [rfm_segment] IN (&quot;Lost&quot;, &quot;At Risk&quot;) THEN 1 ELSE 0 END) &#13;&#10;/ &#13;&#10;COUNT([customer_id]) * 100' />
      </column>
      <column caption='Monetary ' datatype='real' name='[Calculation_1683139838271492]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[monetary]/1000' />
      </column>
      <column caption='Avg LTV' datatype='real' default-format='n#,##0' name='[Calculation_175556608613739615]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(IIF([rfm_segment] != &quot;Never Purchased&quot;, [monetary], NULL))' />
      </column>
      <column caption='Churn Rate %' datatype='real' default-format='p1%' name='[Calculation_256607393923822570]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [rfm_segment] IN (&quot;Lost&quot;,&quot;At Risk&quot;) THEN 1 ELSE 0 END) / COUNT([customer_id]) * 100' />
      </column>
      <column caption='Total Customers' datatype='integer' default-format='n#,##0' name='[Calculation_586054209108793761]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([customer_id])' />
      </column>
      <column caption='Active Customers' datatype='integer' default-format='n#,##0' name='[Calculation_616872061146596607]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [rfm_segment] IN (&quot;Champions&quot;,&quot;Loyal Customers&quot;,&quot;New Customers&quot;,&quot;Potential Loyalists&quot;) THEN 1 ELSE 0 END)' />
      </column>
      <column caption='Is Churn RFM' datatype='integer' name='[Calculation_953761299076553823]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [rfm_segment] IN (&quot;Lost&quot;,&quot;At Risk&quot;) THEN 1 ELSE 0 END' />
      </column>
      <column caption='F Score' datatype='real' name='[F_score]' role='measure' type='quantitative' />
      <column caption='M Score' datatype='real' name='[M_score]' role='measure' type='quantitative' />
      <column caption='Rfm Score' datatype='real' name='[RFM_score]' role='measure' type='quantitative' />
      <column caption='R Score' datatype='real' name='[R_score]' role='measure' type='quantitative' />
      <column caption='agg_cohort_retention.csv' datatype='table' name='[__tableau_internal_object_id__].[agg_cohort_retention.csv_82E43091867040948047138BB99880CA]' role='measure' type='quantitative' />
