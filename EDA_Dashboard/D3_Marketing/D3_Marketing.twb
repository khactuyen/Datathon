    <worksheet name='viz_D3_04_channel_aov'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontname='Tableau Bold' fontsize='16'>Channel AOV Ranked</run>
            <run>Æ&#10;</run>
            <run fontsize='10'><![CDATA[<Sheet Name>  | bars above reference = above-average channels]]></run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='fact_orders_enriched.csv+ (Multiple Connections)' name='federated.12gp2g215xlec316mpojb1kyax00' />
          </datasources>
          <datasource-dependencies datasource='federated.12gp2g215xlec316mpojb1kyax00'>
            <column caption='AOV' datatype='real' default-format='n#,##0,.0K;-#,##0,.0K' name='[Calculation_1719249219220705283]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([payment_value]) / COUNTD([order_id])' />
            </column>
            <column caption='Overall AOV' datatype='real' name='[Calculation_1719249219536687114]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : SUM([payment_value]) / COUNTD([order_id]) }' />
            </column>
            <column caption='Channel AOV' datatype='real' name='[Calculation_1719249219536756747]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [order_source] : SUM([payment_value]) / COUNTD([order_id]) }' />
            </column>
            <column caption='is_above_aov' datatype='boolean' name='[Calculation_1719249219547672592]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Calculation_1719249219536756747] &gt;= [Calculation_1719249219536687114]' />
              <aliases>
                <alias key='false' value='below overall AOV' />
                <alias key='true' value='above overall AOV' />
              </aliases>
            </column>
            <column-instance column='[Calculation_1719249219547672592]' derivation='None' name='[none:Calculation_1719249219547672592:nk]' pivot='key' type='nominal' />
            <column-instance column='[order_source]' derivation='None' name='[none:order_source:nk]' pivot='key' type='nominal' />
            <column caption='Order Id' datatype='integer' name='[order_id]' role='dimension' type='ordinal' />
            <column caption='Order Source' datatype='string' name='[order_source]' role='dimension' type='nominal' />
            <column caption='Payment Value' datatype='real' name='[payment_value]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_1719249219536687114]' derivation='Sum' name='[sum:Calculation_1719249219536687114:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1719249219536756747]' derivation='Sum' name='[sum:Calculation_1719249219536756747:qk]' pivot='key' type='quantitative' />
