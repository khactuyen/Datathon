      <aliases enabled='yes' />
      <column caption='Total Orders' datatype='integer' name='[Calculation_1719249219220373504]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([order_id])' />
      </column>
      <column caption='Promo Orders %' datatype='real' default-format='p0.0%' name='[Calculation_1719249219220533249]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [has_promo] = 1 THEN [order_id] END)&#13;&#10;/ COUNTD([order_id])' />
      </column>
      <column caption='Avg Discount %' datatype='real' default-format='n#,##0.0&quot;%&quot;;-#,##0.0&quot;%&quot;' name='[Calculation_1719249219220619266]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(IF [has_promo] = 1 THEN [discount_pct] END)' />
      </column>
      <column caption='AOV' datatype='real' default-format='n#,##0,.0K;-#,##0,.0K' name='[Calculation_1719249219220705283]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([payment_value]) / COUNTD([order_id])' />
      </column>
      <column caption='Revenue Share %' datatype='real' name='[Calculation_1719249219220791300]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([line_revenue])' />
      </column>
      <column caption='Promo Label' datatype='string' name='[Calculation_1719249219530047496]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [has_promo] = 1 THEN &quot;With Promo&quot; ELSE &quot;No Promo&quot; END' />
      </column>
      <column caption='AOV per Order' datatype='real' name='[Calculation_1719249219530166281]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([payment_value]) / COUNTD([order_id])' />
      </column>
      <column caption='Overall AOV' datatype='real' name='[Calculation_1719249219536687114]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : SUM([payment_value]) / COUNTD([order_id]) }' />
      </column>
      <column caption='Channel AOV' datatype='real' name='[Calculation_1719249219536756747]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [order_source] : SUM([payment_value]) / COUNTD([order_id]) }' />
      </column>
      <column caption='is_above_aov' datatype='boolean' name='[Calculation_1719249219547672592]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Calculation_1719249219536756747] &gt;= [Calculation_1719249219536687114]' />
        <aliases>
          <alias key='false' value='below overall AOV' />
          <alias key='true' value='above overall AOV' />
        </aliases>
      </column>
