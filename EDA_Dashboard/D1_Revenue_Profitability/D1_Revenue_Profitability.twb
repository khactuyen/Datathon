      <aliases enabled='yes' />
      <column caption='flt_year_sales' datatype='boolean' name='[Calculation_2091677259735043]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[year] = [Parameters].[Parameter 1]' />
      </column>
      <column caption='Revenue CAGR 2013-2022' datatype='real' default-format='p1%' name='[Calculation_303666600585833839]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(POWER( SUM(IIF(YEAR([date])=2022,[revenue],0)) / SUM(IIF(YEAR([date])=2013,[revenue],0)) , 1/9) - 1)' />
      </column>
      <column caption='Gross Profit' datatype='real' default-format='n#,##0' name='[Calculation_347072634211033817]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([gross_profit])' />
      </column>
      <column caption='Gross Margin %' datatype='real' default-format='p1%' name='[Calculation_768322346932056072]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_347072634211033817] / SUM([revenue])' />
      </column>
      <column caption='Gross Margin Pct' datatype='real' name='[Calculation_858305185499730153]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([gross_profit]) / SUM([revenue]) * 100' />
      </column>
      <column caption='Total Revenue' datatype='real' default-format='n#,##0' name='[Calculation_902387848493404320]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([revenue])' />
      </column>
      <column caption='CAGR 2013 to 2022 Pct' datatype='real' name='[Calculation_995195776966223500]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(POWER( SUM(IIF(YEAR([date])=2022,[revenue],0)) / SUM(IIF(YEAR([date])=2013,[revenue],0)) , 1/9) - 1) * 100' />
      </column>
