    <worksheet name='kpi_D1_04_cagr'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#c0c0c0' fontname='Open Sans,system-ui,sans-serif' fontsize='18'>REVENUE CAGR</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='DS Revenue' name='federated.665b76793c9e4fdfb219fddcf2e2c1b6' />
          </datasources>
          <datasource-dependencies datasource='federated.665b76793c9e4fdfb219fddcf2e2c1b6'>
            <column caption='Revenue CAGR 2013-2022' datatype='real' default-format='p1%' name='[Calculation_303666600585833839]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(POWER( SUM(IIF(YEAR([date])=2022,[revenue],0)) / SUM(IIF(YEAR([date])=2013,[revenue],0)) , 1/9) - 1)' />
            </column>
            <column caption='Date' datatype='date' name='[date]' role='dimension' type='ordinal' />
            <column caption='Revenue' datatype='real' name='[revenue]' role='measure' type='quantitative' />
          </datasource-dependencies>
